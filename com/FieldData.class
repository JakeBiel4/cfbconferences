public class FieldData {
    private Object data;
    private DataField field;

    public FieldData(DataField f, Object o) {
        this.field = f;
        this.data = o;
    }

    public void setData(Object o) {
        this.data = o;
    }

    public Object getData() {
        try {
            return this.field.getDataType().cast(this.data);
        } catch (ClassCastException var2) {
            return (Double)this.data == (double)1.0F;
        }
    }

    public DataField getField() {
        return this.field;
    }
}